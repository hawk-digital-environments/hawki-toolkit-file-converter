# USE AN STRONG API KEY HERE
F_API_KEY=123

# PostgreSQL settings (production default: local postgres inside container)
# Set to "false" to disable the internal postgres and use your own database URL
POSTGRES_ENABLED=true
PREFECT_API_DATABASE_CONNECTION_URL=postgresql+asyncpg://prefect@127.0.0.1:5432/prefect

# Alternative: Use SQLite (for development / CI)
# POSTGRES_ENABLED=false
# PREFECT_API_DATABASE_CONNECTION_URL=sqlite+aiosqlite:////var/www/.prefect/prefect.db?timeout=60

# Alternative: Use external PostgreSQL
# POSTGRES_ENABLED=false
# PREFECT_API_DATABASE_CONNECTION_URL=postgresql+asyncpg://user:password@db.example.com:5432/prefect
