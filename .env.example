# USE AN STRONG API KEY HERE
F_API_KEY=123

# PostgreSQL settings (production default: local postgres inside container)
# Set to "false" to disable the internal postgres and use your own database URL
POSTGRES_ENABLED=true

# Temporal settings (used by main.py and the worker)
# These match the in-container temporal server. Override only if you point
# the API/worker at an external Temporal instance.
TEMPORAL_HOST=127.0.0.1:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=file-converter

# Alternative: Point at an external Temporal instance
# POSTGRES_ENABLED=false
# TEMPORAL_HOST=temporal.example.com:7233
# TEMPORAL_NAMESPACE=production

# Async /convert pipeline
# How long (in hours) a result zip remains downloadable after the most
# recent access. The TTL is renewed on every /download, so an actively
# downloaded zip effectively never expires. A Temporal Schedule sweeps
# SHARED_TMP every 15 minutes and deletes expired job directories.
#
# IMPORTANT: Must be <= DEFAULT_NAMESPACE_RETENTION (Temporal, see Dockerfile).
# The /download and /jobs endpoints query Temporal for the workflow record.
# Once retention purges the workflow, /download/{job_id} returns 404 and
# /jobs/{job_id} returns 404 -- even if the zip file is still on disk.
# Keep ZIP_TTL_HOURS <= DEFAULT_NAMESPACE_RETENTION so the zip disappears
# before the workflow record does.
ZIP_TTL_HOURS=24

# Per-request timeout for outbound callback POSTs invoked from inside the
# workflow when a callback_url was supplied to /convert.
CALLBACK_TIMEOUT_SECONDS=30

# Maximum time (in minutes) a single file conversion activity can run
# before Temporal considers it timed out. Large or complex files (e.g.
# PDFs with many pages, heavy OCR) may need a longer timeout.
PROCESS_FILE_TIMEOUT_MINUTES=60

# Maximum number of concurrent workflow tasks the worker will process at a
# time (passed as max_concurrent_workflow_tasks to the Temporal SDK Worker).
# Each workflow task is lightweight (sequencing steps) while the real work
# happens in activities. Increase this only if you need to pipeline many
# short-lived conversions through the worker. Temporal default is 100.
TEMPORAL_MAX_CONCURRENT=5

# Sticky workflow cache size for the Temporal worker. When nonzero, completed
# workflow tasks are kept in memory so the next task for that workflow runs on
# the same worker (sticky) without replaying history. Set to 0 to disable
# caching entirely (lowest memory; each task replays history). Our workflows
# are short with tiny histories, so replay is cheap and 0 is a good default.
# Temporal default is 1000
TEMPORAL_MAX_CACHED_WORKFLOWS=1000
